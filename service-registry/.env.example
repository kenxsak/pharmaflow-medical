# Service Registry Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
EUREKA_PORT=8761
EUREKA_HOSTNAME=localhost

# Security Credentials
EUREKA_USERNAME=admin
EUREKA_PASSWORD=your-secure-password

# Self Preservation (set to false for development)
EUREKA_SELF_PRESERVATION=true

# Logging
LOG_PATH=./logs

# Environment
ENVIRONMENT=development
